# Produktions-Variante von .env.example — gleiche Variablen, aber mit
# produktionsscharfen Anforderungen/Defaults kommentiert. Nach `.env`
# kopieren (Docker/Compose liest diese Datei automatisch, siehe
# docker-compose.yml) oder in die Umgebung des Prozessmanagers eintragen.
# Niemals echte Werte committen — .env* ist in .gitignore.
#
# Vollständige Beschreibung jeder Variable: siehe .env.example. Diese Datei
# wiederholt nur, was sich in Produktion ändert oder zur Pflicht wird.

# ---------------------------------------------------------------------------
# Prozess / Runtime
# ---------------------------------------------------------------------------

# In Docker bereits in Dockerfile/docker-compose.yml gesetzt — hier nur für
# einen Nicht-Docker-Betrieb relevant (z. B. PM2 auf Hetzner, siehe
# DEPLOYMENT.md). Next.js' Production-Compiler-Pfad UND next.config.ts's
# Velite-Aufruf hängen davon ab (siehe Dockerfile-Kommentar).
NODE_ENV=production

# Nur falls nginx auf einen anderen Port als 3000 proxyt.
PORT=3000

# ---------------------------------------------------------------------------
# Site — in Produktion PFLICHT (nicht der localhost-Fallback)
# ---------------------------------------------------------------------------

NEXT_PUBLIC_SITE_URL=https://neuralcraft.ai

# ---------------------------------------------------------------------------
# E-Mail (Resend) — in Produktion sollte RESEND_API_KEY gesetzt sein
# ---------------------------------------------------------------------------

# Ohne echten Key läuft die Seite weiter, aber niemand bekommt eine Antwort
# auf eine Kontaktanfrage — vor dem Go-Live unbedingt konfigurieren (siehe
# DEPLOYMENT.md, Abschnitt „Resend").
RESEND_API_KEY=
CONTACT_EMAIL_FROM="NeuralCraft <hello@neuralcraft.ai>"
CONTACT_EMAIL_TO=hello@neuralcraft.ai

# ---------------------------------------------------------------------------
# Spam-Schutz (optional, siehe lib/spam-protection.ts)
# ---------------------------------------------------------------------------

TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ---------------------------------------------------------------------------
# Analytics (optional, siehe lib/analytics.ts)
# ---------------------------------------------------------------------------

NEXT_PUBLIC_ANALYTICS_PROVIDER=
NEXT_PUBLIC_ANALYTICS_DOMAIN=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_SCRIPT_URL=

# ---------------------------------------------------------------------------
# Next.js Server Actions — empfohlen zu setzen, sobald mehr als ein
# Node-Prozess läuft (mehrere PM2-Instanzen oder mehrere Container hinter
# demselben nginx)
# ---------------------------------------------------------------------------

# Muss über alle Instanzen identisch sein, sonst schlagen Server-Action-
# Aufrufe fehl, die auf einer anderen Instanz landen als der, die sie
# erzeugt hat. Einzelne Instanz: kann entfallen.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Kopiere diese Datei zu .env.local (lokal) bzw. .env (Server) und trage
# echte Werte ein. .env* ist in .gitignore — niemals echte Secrets committen.
# Details zu Deployment/Hetzner: siehe DEPLOYMENT.md.

# ---------------------------------------------------------------------------
# Site
# ---------------------------------------------------------------------------

# Öffentliche Basis-URL der Seite (ohne trailing slash). Wird für
# metadataBase, hreflang-Alternates, den RSS-Feed sowie sitemap.xml/
# robots.txt verwendet. Fallback: http://localhost:3000 (siehe lib/site.ts).
NEXT_PUBLIC_SITE_URL=https://neuralcraft.ai

# ---------------------------------------------------------------------------
# E-Mail (Resend) — siehe lib/email/
# ---------------------------------------------------------------------------

# Ohne diesen Key wird keine E-Mail versendet: das Kontaktformular
# funktioniert weiterhin (Einsendungen werden geloggt), verschickt aber
# weder Bestätigungs- noch Benachrichtigungs-Mail. Siehe
# lib/email/resend-client.ts.
RESEND_API_KEY=

# Absenderadresse für beide Kontaktformular-E-Mails. Muss eine bei Resend
# verifizierte Domain nutzen, sobald ein echter Key hinterlegt ist.
CONTACT_EMAIL_FROM="NeuralCraft <hello@neuralcraft.ai>"

# Empfänger der internen Benachrichtigung bei neuen Kontaktanfragen.
CONTACT_EMAIL_TO=hello@neuralcraft.ai

# ---------------------------------------------------------------------------
# Spam-Schutz — siehe lib/spam-protection.ts
# ---------------------------------------------------------------------------

# Cloudflare Turnstile ist vorbereitet, aber inaktiv, bis dieser Wert gesetzt
# ist (Verifikation ist bis dahin ein No-op). Zum Aktivieren zusätzlich das
# Widget in components/contact/contact-form.tsx einbinden.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ---------------------------------------------------------------------------
# Analytics — siehe lib/analytics.ts (noch kein Dienst aktiv)
# ---------------------------------------------------------------------------

# Einer von: plausible | google-analytics | umami. Leer/unset = keine
# Analytics-Skripte werden geladen. next.config.ts erweitert die
# Content-Security-Policy automatisch um die Domain des gewählten Anbieters.
NEXT_PUBLIC_ANALYTICS_PROVIDER=

# Nur bei NEXT_PUBLIC_ANALYTICS_PROVIDER=plausible:
NEXT_PUBLIC_ANALYTICS_DOMAIN=

# Nur bei NEXT_PUBLIC_ANALYTICS_PROVIDER=google-analytics:
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Nur bei NEXT_PUBLIC_ANALYTICS_PROVIDER=umami:
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_SCRIPT_URL=

# ---------------------------------------------------------------------------
# Next.js Server Actions — nur für Multi-Instanz-Deployments relevant
# ---------------------------------------------------------------------------

# Läuft die App auf mehreren Node-Prozessen/Containern gleichzeitig (z. B.
# mehrere PM2-Instanzen hinter demselben nginx auf Hetzner), muss dieser Key
# über alle Instanzen hinweg identisch und stabil sein, sonst schlagen
# Server-Action-Aufrufe fehl, die auf einer anderen Instanz landen als der,
# die sie erzeugt hat. Bei einer einzelnen Instanz kann er entfallen. Siehe
# Next.js-Doku zu Server Actions / Closures & Encryption.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

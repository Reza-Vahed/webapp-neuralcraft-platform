# Development image: hot-reload via `next dev` (Turbopack), source mounted
# as a volume by docker-compose.yml. Not used for production — see
# Dockerfile for the multi-stage production build.
FROM node:22-alpine

WORKDIR /app

ENV HUSKY=0
ENV NEXT_TELEMETRY_DISABLED=1

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

CMD ["npm", "run", "dev"]

# Keeps the build context small and, more importantly, guarantees local
# secrets and git history never end up inside an image layer.

# dependencies (reinstalled inside the image — see Dockerfile)
node_modules
.pnp
.pnp.*

# next.js / velite build output (regenerated inside the image)
.next
out
.velite
public/static

# git
.git
.gitignore

# env files — never bake secrets into an image (see .env.example)
.env
.env*.local
.env.development
.env.production
.env.test

# docker itself
Dockerfile*
docker-compose*.yml
.dockerignore

# CI/CD
.github

# editor/OS noise
.vscode
.idea
.DS_Store
*.pem

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# docs (not needed at runtime)
*.md
!README.md

# misc
coverage
*.tsbuildinfo
.husky

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# velite (generated content data layer)
/.velite/
/public/static/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — but not the secret-free .example templates, which document
# every variable and must be committed (see DEPLOYMENT.md). Found via a
# `git status` check in Phase 10: this broad pattern had silently excluded
# .env.example from every commit since it was introduced in Phase 9.
.env*
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
